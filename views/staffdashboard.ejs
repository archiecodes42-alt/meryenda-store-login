<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="staff.css">
    <title>Meryenda Store</title>
    <!-- Styles are already in your existing file -->
</head>
<body>

<nav class="header-navbar">
  <div class="brandname">
    <div class="logo">
      <img src="/Meryenda.jpg" alt="Meryenda Store Logo" class="logo-img" onerror="this.src='https://via.placeholder.com/60/E67E22/FFFFFF?text=MS'">
    </div>
    <h2>Meryenda Store</h2>
    
    <div class="Contacts"><h6>Contact: 09363773992</h6></div>
    <div class="Location"><h6>City Of San Jose Del Monte Bulacan</h6></div>
  </div>

  <div class="logout-btn">
    <a href="/logout"><button>Logout</button></a>
  </div>
</nav>

<div class="staffdashboard">
  <div class="dashboard">

    <div class="sidebar">
      <h2>Category</h2>
      <br>

      <button class="category-btn active" id="category1" data-category="all">All Products</button>
      <br>
      <button class="category-btn" id="category2" data-category="Pancit Canton">Pancit Canton</button>
      <br>
      <button class="category-btn" id="category3" data-category="Rice Meals">Rice Meals</button>
      <br>
      <button class="category-btn" id="category4" data-category="Sandwiches">Sandwiches</button>
      <br>
      <button class="category-btn" id="category5" data-category="Drinks">Drinks</button>
      <br>
      <button class="category-btn" id="category6" data-category="Coffee">Coffee</button>
      <br>
      <button class="category-btn" id="category9" data-category="Snacks">Snacks</button>
      <br>     
      <button class="category-btn" id="category11" data-category="Yakisoba">Yakisoba</button>
      <br>
      <button class="category-btn" id="category12" data-category="Pasta Express">Pasta Express</button>
      <br>
      <button class="category-btn" id="category-btn13" data-category="Candy">Candy</button>
      <br>
      <footer>&copy; <span id="currentYear"></span> Meryenda Store.</footer>
    </div>

    <div class="center"> 
      <input type="text" class="search" placeholder="Search Menu" id="searchInput">
      <div id="menuContainer" class="menu-grid">
        <!-- Menu items will be loaded by JavaScript -->
      </div>
    </div>

    <!-- CART -->
    <div class="product">
      <h3>Products</h3>
      <p>Payment Type: <span id="paymentMethodDisplay">None</span></p>
      <p>Order Type: <span id="orderTypeDisplay">None</span></p>
      <p>Change: ₱<span id="changeAmount">0.00</span></p>
      <ul id="productlist"></ul>

      <div class="totals">
        <p>Subtotal: <span id="subtotal">0.00</span></p>
        <h3>Total Amount: ₱<span id="totals">0.00</span></h3>
      </div>
      
      <div class="payment-section">
        <div class="order-type-row">
          <button class="dineinandtakeout-btn" id="dineInBtn">Dine In</button>
          <button class="dineinandtakeout-btn" id="takeOutBtn">Take Out</button>
        </div>

        <div class="customer-info">
        </div>
      </div>

      <div class="payment-methods">
        <h3>Payment Method</h3>
        <br>
        <button id="cash-btn" class="payment-method-btn">Cash</button>
        <button id="gcash-btn" class="payment-method-btn">Gcash</button>
        
        <div class="input-payment-section" id="cashPaymentSection" style="display: none;">
          <h3>Input Payment</h3>
          <input type="number" id="inputPayment" class="input-payment" placeholder="Enter payment amount">
        </div>
      </div>
      
      <button class="pay-btn" id="payment-btn" disabled>Pay</button>
    </div>
  </div>
</div>

<!-- Receipt Modal -->
<div id="receiptModal">
  <div class="receipt-container">
    <div style="text-align: center; margin-bottom: 15px;">
      <h2>MERYENDA STORE</h2>
      <p>Contact: 09363773992</p>
      <p>City Of San Jose Del Monte Bulacan</p>
      <div class="separator"></div>
    </div>
    
    <p style="text-align: center;"><strong>ORDER RECEIPT</strong></p>
    <p id="receiptOrderType" style="text-align: center;">[Order Type]</p>
    <p id="receiptDateTime" style="text-align: center;">[Date/Time]</p>
    <p id="receiptOrderId" style="text-align: center; font-size: 0.9rem; color: #666;">Order ID: [Order ID]</p>
    <div class="separator"></div>
    
    <table id="receiptTable">
      <thead>
        <tr>
          <th>Item</th>
          <th>Qty</th>
          <th>Price</th>
        </tr>
      </thead>
      <tbody>
        <!-- Items will be populated here -->
      </tbody>
    </table>
    
    <div class="separator"></div>
    
    <div class="totals-section">
      <p>
        <span>Subtotal:</span>
        <span>₱<span id="receiptSubtotal">0.00</span></span>
      </p>
      <p>
        <span>Tax (12%):</span>
        <span>₱<span id="receiptTax">0.00</span></span>
      </p>
      <h3>
        <span>TOTAL:</span>
        <span>₱<span id="receiptTotal">0.00</span></span>
      </h3>
      <p>
        <span>Amount Paid:</span>
        <span>₱<span id="receiptAmountPaid">0.00</span></span>
      </p>
      <p>
        <span>Change:</span>
        <span>₱<span id="receiptChange">0.00</span></span>
      </p>
    </div>
    
    <div class="footer">
      <div class="thank-you">
        THANK YOU. PLEASE COME AGAIN.
      </div>
      <div class="receipt-info">
        This serves as a SALES INVOICE
      </div>
    </div>
    
    <button class="close-receipt" id="closeReceiptBtn">Close Receipt</button>
  </div>
</div>

<!-- Notification -->
<div id="notification" class="notification"></div>

<script src="/script/staff.js"></script>
</body>
</html>